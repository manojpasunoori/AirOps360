{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://airops360.local/schemas/baggage-scan.schema.json",
  "title": "BaggageScanEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "occurredAt",
    "bagTag",
    "flightNumber",
    "scanPoint",
    "scanStatus"
  ],
  "properties": {
    "eventId": { "type": "string", "minLength": 8 },
    "eventType": { "const": "baggage.scan" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "bagTag": { "type": "string", "minLength": 4, "maxLength": 32 },
    "flightNumber": { "type": "string", "minLength": 2, "maxLength": 16 },
    "scanPoint": { "type": "string", "minLength": 2, "maxLength": 64 },
    "scanStatus": {
      "type": "string",
      "enum": ["RECEIVED", "SCREENED", "SORTED", "LOADED", "MISROUTED", "ARRIVED", "PROCESSED"]
    },
    "workerId": { "type": ["string", "null"], "maxLength": 32 },
    "passengerReference": { "type": ["string", "null"], "maxLength": 64 }
  }
}
