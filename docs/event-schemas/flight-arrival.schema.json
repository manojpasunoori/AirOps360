{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://airops360.local/schemas/flight-arrival.schema.json",
  "title": "FlightArrivalEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "occurredAt",
    "flightNumber",
    "airlineCode",
    "originAirport",
    "destinationAirport",
    "scheduledArrival",
    "status",
    "source"
  ],
  "properties": {
    "eventId": { "type": "string", "minLength": 8 },
    "eventType": { "const": "flight.arrival" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "flightNumber": { "type": "string", "minLength": 2, "maxLength": 16 },
    "airlineCode": { "type": "string", "minLength": 2, "maxLength": 8 },
    "originAirport": { "type": "string", "minLength": 3, "maxLength": 3 },
    "destinationAirport": { "type": "string", "minLength": 3, "maxLength": 3 },
    "scheduledArrival": { "type": "string", "format": "date-time" },
    "estimatedArrival": { "type": ["string", "null"], "format": "date-time" },
    "actualArrival": { "type": ["string", "null"], "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["SCHEDULED", "EN_ROUTE", "LANDED", "ARRIVED", "DELAYED", "CANCELLED"]
    },
    "gate": { "type": ["string", "null"], "maxLength": 12 },
    "source": { "type": "string", "minLength": 2, "maxLength": 32 }
  }
}
