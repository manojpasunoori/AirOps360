{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://airops360.local/schemas/warehouse-receive.schema.json",
  "title": "WarehouseReceiveEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "occurredAt",
    "manifestReference",
    "sku",
    "storageZone",
    "quantity",
    "receivedBy"
  ],
  "properties": {
    "eventId": { "type": "string", "minLength": 8 },
    "eventType": { "const": "warehouse.receive" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "manifestReference": { "type": "string", "minLength": 3, "maxLength": 40 },
    "sku": { "type": "string", "minLength": 3, "maxLength": 40 },
    "storageZone": { "type": "string", "minLength": 2, "maxLength": 24 },
    "quantity": { "type": "integer", "minimum": 1 },
    "receivedBy": { "type": "string", "minLength": 2, "maxLength": 32 }
  }
}
